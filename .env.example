# Email Alert Configuration
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password
RECIPIENT_EMAIL=recipient@gmail.com

# Alert Settings
EMAIL_ALERTS_ENABLED=True
SOUND_ALERTS_ENABLED=True

# Detection Settings
PANIC_DENSITY_THRESHOLD=10
PANIC_MOVEMENT_THRESHOLD=50
MIN_DETECTION_CONFIDENCE=0.4
SUSTAINED_ALERT_FRAMES=5

# Flask Dashboard
FLASK_PORT=5001
FLASK_DEBUG=False

# Input Source
# 0 = webcam, or path to video file, or RTSP stream URL
INPUT_SOURCE=0
